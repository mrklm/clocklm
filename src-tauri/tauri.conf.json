{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Clocklm",
  "version": "1.0.75",
  "identifier": "com.clocklm.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:5173",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Clocklm",
        "width": 1280,
        "height": 800,
        "minWidth": 960,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false
      },
      {
        "label": "vu-meter-window",
        "title": "Clocklm VU-metre",
        "url": "vu-meter.html",
        "width": 560,
        "height": 320,
        "minWidth": 360,
        "minHeight": 220,
        "resizable": true,
        "visible": false,
        "decorations": true,
        "fullscreen": false,
        "focus": true
      }
    ],
    "security": {
      "csp": null,
      "assetProtocol": {
        "enable": true,
        "scope": {
          "allow": [
            "$HOME/**"
          ]
        }
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": [
      "appimage",
      "msi",
      "dmg"
    ],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
